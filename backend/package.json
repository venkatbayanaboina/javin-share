{
  "name": "javin-fileshare-backend",
  "version": "2.0.0",
  "description": "JAVIN FileShare — local-network file sharing server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --import ./test/setup-env.mjs --test test/**/*.test.mjs",
    "test:opt": "node --import ./test/setup-env.mjs --test test/integration/transfer-optimization.test.mjs",
    "test:unit": "node --import ./test/setup-env.mjs --test test/unit/**/*.test.mjs",
    "test:integration": "node --import ./test/setup-env.mjs --test test/integration/**/*.test.mjs",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.mjs\""
  },
  "keywords": [
    "file-sharing",
    "local-network",
    "websockets"
  ],
  "author": "JAVIN FileShare",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "express": "^4.18.2",
    "multicast-dns": "^7.2.5",
    "nanoid": "^5.0.4",
    "open": "^9.1.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/venkatbayanaboina/Javin-Share-.git"
  }
}
