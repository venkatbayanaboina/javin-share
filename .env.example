# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
OPEN_BROWSER=true

# Session
PIN_EXPIRY_MS=300000
GRACE_PERIOD_MS=30000
MAX_GRACE_MS=120000

# Transfer
MAX_FILE_SIZE_BYTES=53687091200
MAX_CONCURRENT_DOWNLOADS=3

# Security (PIN brute-force protection)
PIN_MAX_ATTEMPTS=8
PIN_RATE_WINDOW_MS=900000
PIN_LOCKOUT_MS=300000
UPLOADS_DIR=./backend/uploads

# TLS (generated locally by setup scripts)
CERTS_DIR=./backend/certs

# Transfer optimization (post-restructure — Section 23)
TRANSFER_DEFAULT_STRATEGY=relay-disk
TRANSFER_ENABLE_STREAM_RELAY=false
TRANSFER_ENABLE_P2P=false
TRANSFER_SPOOL_THRESHOLD_BYTES=268435456
